views:
  - type: table
    name: Table
    filters:
      and:
        - '!file.inFolder("Novel Tracker")'
        - file.ext == "md"
        - '!file.inFolder("_metadata")'
        - '!file.inFolder("covers")'
    order:
      - file.name
      - status
      - current-chapter
      - total-chapters
      - file.mtime
      - source-url
      - author
    sort:
      - property: status
        direction: DESC
      - property: file.mtime
        direction: DESC
